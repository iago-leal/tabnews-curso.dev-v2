      "link": null,
      "locked": false,
      "text": "`nvm alias default <version>`\nMesmo que feche o terminal, esse será o novo padrão.\nEntão, vamos utilizar `nvm alias default lts/hydrogen`\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "`nvm alias default <version>`\nMesmo que feche o terminal, esse será o novo padrão.\nEntão, vamos utilizar `nvm alias default lts/hydrogen`\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
